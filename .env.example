# =============================================================================
# 本番環境用 .env テンプレート
#
# このファイルをコピーして `.env` を作成し、各値を埋めて使う。
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Database
# =============================================================================

# PostgreSQL のパスワード。本番では強固なものに変更する。
# `db` サービスの初期化と DATABASE_URL の構築の両方で使われる。
POSTGRES_PASSWORD=changeme

# DATABASE_URL は docker-compose.yml で `db` サービスを参照する形で構築される。
# ホストから alembic を直接実行する場合のみ、以下のようにオーバーライドする。
# DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/kikitoru

# PostgreSQL の SSL モード。docker-compose で同一ホストの DB に繋ぐなら disable で OK。
# クラウド managed DB (RDS, Cloud SQL, Supabase 等) や別ホストの Postgres に
# 繋ぐ場合は 'verify-full' を使うこと (サーバ証明書とホスト名を検証する)。
# 注意: 'require' は暗号化のみで証明書を検証しないため、能動的な MITM は防げない。
# verify-ca / verify-full では CA を指定する (sslrootcert)。
DATABASE_SSL_MODE=verify-full

# =============================================================================
# External APIs
# =============================================================================

# Hugging Face のアクセストークン。pyannote.audio (話者ダイアライゼーション) の
# モデルをダウンロードするために必須。https://huggingface.co/settings/tokens で取得。
HF_TOKEN=your_huggingface_token

# Google AI Studio の API キー。Gemini (要約 LLM) を呼び出すために必須。
# https://aistudio.google.com/apikey で取得。
GOOGLE_API_KEY=your_google_api_key

# =============================================================================
# Google OAuth (KKT/9 認証実装)
# =============================================================================

# Google Cloud Console > APIs & Services > Credentials で
# OAuth 2.0 Client ID (Web application) を作成して取得。
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# OAuth callback URL。Google Cloud Console の "Authorized redirect URIs" にも
# 同じ URL を登録する必要がある。
GOOGLE_REDIRECT_URI=https://your-domain.example.com/auth/google/callback

# =============================================================================
# Cookie / Session
# =============================================================================

# 本番では必ず true (HTTPS 必須)。HTTP では cookie が送信されなくなる。
COOKIE_SECURE=true

# セッションの有効期間 (日数)。デフォルト 30 日。
SESSION_EXPIRY_DAYS=30

# =============================================================================
# CORS
# =============================================================================

# CORS で許可するオリジン。JSON 配列形式で指定。
# 本番ではフロントエンドの本番 URL に変更する。
ALLOWED_ORIGINS=["https://your-frontend.example.com"]

# =============================================================================
# LLM Settings
# =============================================================================

# LLM 呼び出し1回あたりのタイムアウト (秒)。長い文字起こしでは長めに設定する。
LLM_TIMEOUT_SECONDS=120

# 同時に走らせる LLM リクエスト数の上限 (デフォルト: 80)
# LLM_CONCURRENT_LIMIT=80

# =============================================================================
# STT Settings
# =============================================================================

# Whisper モデルのプールサイズ。同時に保持する STT モデルインスタンス数 (デフォルト: 5)
# STT_POOL_SIZE=5

# STT モデルがアイドル状態でアンロードされるまでの秒数 (デフォルト: 300)
# STT_IDLE_TIMEOUT_SECONDS=300

# =============================================================================
# Deployment
# =============================================================================

# /docs, /redoc, /openapi.json を公開するかどうか。
# 本番では false にして攻撃面の enumeration を防ぐ。
ENABLE_DOCS=false

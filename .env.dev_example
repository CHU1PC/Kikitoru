# =============================================================================
# Database
# =============================================================================

# 開発用パスワード。実値は何でもいいが、docker-compose が要求する。
POSTGRES_PASSWORD=dev_password

# ホストから alembic を直接実行するために設定。
# docker-compose.dev.yml の db サービスでホストの 5432 にポート公開されている前提。
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@localhost:5432/kikitoru

# ローカル開発では SSL 不要 (loopback)。
DATABASE_SSL_MODE=disable

# =============================================================================
# External APIs
# =============================================================================

# 開発用 Hugging Face トークン
HF_TOKEN=your_huggingface_token

# 開発用 Google AI Studio API キー
GOOGLE_API_KEY=your_google_api_key

# =============================================================================
# Google OAuth (開発用)
# =============================================================================

# 開発用は本番とは別の OAuth クライアントを作るのを強く推奨 (本番認証情報を漏らさないため)。
# Google Cloud Console で別プロジェクトを作るか、同じプロジェクト内で
# "Web application" のクライアントをもう 1 つ作成する。
GOOGLE_CLIENT_ID=your-dev-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_dev_client_secret

# ローカル開発のリダイレクト URI。
# Google Cloud Console の "Authorized redirect URIs" に登録すること。
# http:// で OK (localhost は Google が特例で許可している)。
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# =============================================================================
# Cookie / Session
# =============================================================================

# 開発では HTTP でも cookie を送りたいので false。
# 本番では絶対に true にすること。
COOKIE_SECURE=false

# 開発では短めにしてセッション切れ動作のテストをしやすく。
SESSION_EXPIRY_DAYS=1

# =============================================================================
# CORS
# =============================================================================

# Vite dev server (5173) と FastAPI 自身 (8000) を許可。
# 値はシングルクォートで囲む (bash source で " が strip されないように)。
ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:8000"]'

# =============================================================================
# LLM Settings
# =============================================================================

# 開発では長めにしてデバッグしやすく。
LLM_TIMEOUT_SECONDS=120

# 開発では同時実行数を下げてリソース節約。
# LLM_CONCURRENT_LIMIT=10

# =============================================================================
# STT Settings
# =============================================================================

# 開発では小さくして起動を速く。
# STT_POOL_SIZE=2

# STT_IDLE_TIMEOUT_SECONDS=300

# =============================================================================
# Deployment
# =============================================================================

# 開発では /docs を有効に。
ENABLE_DOCS=true
